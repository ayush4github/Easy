def reverse_string(string):
    string = list(string)
    left = 0
    right = len(string)-1
    while left < right:
        string[left], string[right] = string[right], string[left]
        left = left +1
        right = right-1
        return "".join(string)
    text = input("Enter your string here: ")
    reversed_string = reverse_string(text)
    print("Reversed string is: ", reversed_string)